#Enter your robinhood username and password here, then save this file in the same directory as a regular python file
# rh=<Set this in your os environment variable with your Robinhood password>
rh_username="your_email@example.com"
# rh_password: Set via RH_PASSWORD environment variable (K8s secret) for headless/container operation.
# If you dont have a premium account then setting this to false will disable buying during the offhours.
premium_account=False
# You need to retrieve the authenticator token from the robinhood app when you enable 2FA with
# an authenticator app, select "manual" as the authenticator app and put the resulting code here.
# https://robinhood.com/us/en/support/articles/twofactor-authentication/
# RH_DEVICE_TOKEN explanation: https://github.com/jmfernandes/robin_stocks/issues/296#issuecomment-872740673
RH_DEVICE_TOKEN="YOUR_16_CHAR_TOKEN"
# change to false to run in debug mode.
debug=False
# set to show plot; if set to false plot will not show
# beware, if plot is set to true it will stop execution
# of this program until the plot diagram window is closed.
plot=False
verbose=True
# Email settings for SMS notifications (uses email-to-SMS gateways)
# rh_email: Your email address for sending notifications
rh_email="your_email@example.com"
# rh_mail_password: App password for your email (not your regular password)
# For Gmail, create an app password at: https://myaccount.google.com/apppasswords
rh_mail_password="your_app_password"
# rh_phone: Your phone number (digits only, no dashes or spaces)
rh_phone="5551234567"
# rh_company_url: Your carrier's email-to-SMS gateway domain
# Common carriers: vtext.com (Verizon), txt.att.net (AT&T), tmomail.net (T-Mobile), messaging.sprintpcs.com (Sprint)
rh_company_url="vtext.com"
# optimizer_email_recipient: Email address for optimizer completion notifications.
# If not set, notifications go to the SMS gateway (rh_phone@rh_company_url).
# Set to a full email address to receive detailed results instead of/along with SMS.
# optimizer_email_recipient="your_email@example.com"
trade_history_file_name="logs/tradehistory-real.json"
# watch_list_name: Name of your Robinhood watchlist to monitor for potential buys
watch_list_name="Default"
# caution here, if the market tag returns too much data this
# will crash.
# market_tag_for_report: Comma-separated list of Robinhood market tags to scan for potential investments
market_tag_for_report="energy,healthcare,top-movers,most-popular-under-25,blank-check,100-most-popular,technology,etf,media,telecommunications"
market_report_auto_invest=True
# If you decide to not allow specific symbols from being automatically added to the watchlist then set the below value use_exclusion_watchlist
# to true and include the name of your exclusion watchlist here auto_invest_exclusion_watchlist.
use_exclusion_watchlist=True
auto_invest_exclusion_watchlist="Exclusion"
# use_price_cap: If True, only consider stocks below the price_cap value
use_price_cap=True
# price_cap: Maximum stock price to consider for buying (in dollars)
price_cap=4977
# The minimum amount of volume of shares a stock needs to be considered.
min_volume=1000000
# The minimum amount of market cap a stock needs to be considered.
min_market_cap=400000
# Reset the watchlist every week.  Useful for keeping the number of api requests low.
reset_watchlist=True
# clear_watchlist_next_run: If True, the bot will clear the default watchlist on the next run
# and then automatically set this flag back to False. Useful as a fallback when the bot
# wasn't running during the normal Friday night reset window.
clear_watchlist_next_run=False
# Purchase limit mode (controls how purchase_limit_percentage is applied)
#   0 = Legacy: per-stock cap using flawed formula (limit = equity / pct)
#   1 = Total investment cap: pct caps TOTAL invested across all stocks, 1-share exception
#   2 = Per-stock percentage: each stock purchase capped at equity * (pct / 100)
purchase_limit_mode=1
use_purchase_limit_percentage=True
purchase_limit_percentage=9.8
# The below line would be the big "Investing" number on the home view of Robinhood 
# Use this if this app is calculating the wrong initial investment number for you.
# Uncomment and set to your total invested amount
# investing=20000.00

# API rate limiting to avoid hitting Robinhood's rate limits
# Set use_api_rate_limit to False to disable rate limiting
use_api_rate_limit=True
# api_rate_limit: Maximum API requests per minute (Robinhood's limit is ~100/min)
api_rate_limit=99

# Caching to reduce API calls
# Set use_caching to False to disable caching
use_caching=True

# Stop-loss settings
# Set use_stop_loss to True to enable selling when a stock drops below the stop_loss_percent
# This protects against holding losing positions waiting for technical indicators
use_stop_loss=False
# stop_loss_percent: Sell if total loss from buy price exceeds this percentage (e.g., 5 = sell at -5%)
stop_loss_percent=10.7
# Take-profit settings
# take_profit_percent: Sell if total gain from buy price exceeds this percentage (e.g., 1.28 = sell at +1.28%)
take_profit_percent=0.83

# Golden cross buy settings
# golden_cross_buy_days: Number of days to look back for golden cross buy signals
golden_cross_buy_days=7

# SMA (Simple Moving Average) settings
# short_sma: Short-term SMA period in hours (default 20 hours ≈ ~3 trading days)
short_sma=12
# long_sma: Long-term SMA period in hours (default 50 hours ≈ ~7 trading days)
long_sma=78
# short_sma_downtrend: Short-term SMA when market is not in uptrend (more patient to avoid false death crosses)
short_sma_downtrend=20
# short_sma_take_profit: Short-term SMA when take profit triggered and traded today (avoid day trade limit)
short_sma_take_profit=7
# long_sma_take_profit: Long-term SMA when take profit triggered and traded today
long_sma_take_profit=3
# use_dynamic_sma: Enable/disable dynamic SMA adjustment based on market conditions
use_dynamic_sma=False

# Market trend detection settings
# use_market_filter: When True, buying requires market indexes to be in an uptrend.
# When False, the bot will buy on golden crosses regardless of market trend.
use_market_filter=True
# uptrend_threshold_pct: Minimum percentage the index must be above day open to count as uptrend
# (e.g., 0.1 means index must be +0.1% above open, not just any amount above)
uptrend_threshold_pct=0.25
# major_downtrend_threshold_pct: Minimum percentage the index must be below week open to count as major downtrend
# (e.g., 1.0 means index must be -1.0% below week open, filtering out trivial dips)
major_downtrend_threshold_pct=2.4
# use_momentum_check: Enable intraday momentum direction check on indices
# When enabled, a recovering market (was down -1.5%, now only -0.3%) won't trigger downtrend
use_momentum_check=False
# momentum_lookback_bars: Number of 5-minute bars to compare for momentum direction (e.g., 8 = 40 min ago)
momentum_lookback_bars=22

# Slope ordering settings
# use_slope_ordering: When True, stocks are sorted by price slope and only those above slope_threshold are bought.
# When False, slope is not used to filter or order buy candidates.
use_slope_ordering=False
# slope_threshold: Minimum price slope (from linear regression on 5-min bars) for a stock to be considered for buying.
# Stocks with slope below this value are filtered out by order_symbols_by_slope().
# Higher = more selective (fewer buys), Lower = more permissive.
slope_threshold=0.001

# Intraday filter toggles
# use_eod_filter: When True, no new buys after 1:30pm ET (end-of-day filter)
use_eod_filter=False
# use_profit_before_eod: When True, sell profitable positions after 1:30pm ET before market close
use_profit_before_eod=True
# use_price_5hr_check: When True, only buy if current price > price 5 hours ago
use_price_5hr_check=False
# use_price_cross_check: When True, only buy if current price > price at golden cross formation
use_price_cross_check=False

# Version number for tracking
version="0.9.32"