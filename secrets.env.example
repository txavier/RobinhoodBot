# ============================================================================
# RobinhoodBot Deploy Secrets
# ============================================================================
# Copy this file to secrets.env and fill in your values.
# DO NOT commit secrets.env to version control.
#
# cp secrets.env.example secrets.env
# ============================================================================

# SSH connection to the Kubernetes control-plane node
REMOTE_HOST="your-k8s-hostname"
REMOTE_USER="your-username"
REMOTE_DIR="/home/your-username/dev/RobinhoodBot"
