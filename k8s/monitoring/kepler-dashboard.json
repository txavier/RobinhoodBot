{
  "uid": "kepler-power",
  "title": "Kepler / Power Consumption",
  "description": "Node and container power consumption from Kepler eBPF exporter",
  "tags": ["kepler", "power", "energy", "hardware"],
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Node Total Package Power (CPU, Watts)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never",
            "axisCenteredZero": false,
            "axisLabel": "Watts"
          },
          "unit": "watt",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "expr": "rate(kepler_node_package_joules_total[2m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Node Platform Power (Total System, Watts)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never",
            "axisLabel": "Watts"
          },
          "unit": "watt",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "expr": "rate(kepler_node_platform_joules_total[2m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Node DRAM Power (Watts)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisLabel": "Watts"
          },
          "unit": "watt",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "expr": "rate(kepler_node_dram_joules_total[2m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Node Uncore Power (GPU/iGPU, Watts)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisLabel": "Watts"
          },
          "unit": "watt",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "expr": "rate(kepler_node_uncore_joules_total[2m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Top 10 Containers by Package Power (Watts)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 5,
            "showPoints": "never",
            "axisLabel": "Watts"
          },
          "unit": "watt",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true }
      },
      "targets": [
        {
          "expr": "topk(10, rate(kepler_container_package_joules_total[2m]))",
          "legendFormat": "{{pod_name}} / {{container_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Cluster Total Power (Watts)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 400 }
            ]
          },
          "unit": "watt",
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(kepler_node_platform_joules_total[2m]))",
          "legendFormat": "Total Cluster",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Cluster Total CPU Package Power (Watts)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "red", "value": 300 }
            ]
          },
          "unit": "watt",
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(kepler_node_package_joules_total[2m]))",
          "legendFormat": "CPU Package",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Cluster Total DRAM Power (Watts)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          },
          "unit": "watt",
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(kepler_node_dram_joules_total[2m]))",
          "legendFormat": "DRAM",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Nodes Online with Kepler",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "expr": "count(count by (instance) (kepler_node_info))",
          "legendFormat": "Nodes",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Current Cost Rate ($/hr)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 4,
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(kepler_node_platform_joules_total[2m])) / 1000 * ${electricity_cost}",
          "legendFormat": "$/hr",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Estimated Daily Cost ($/day)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.00 },
              { "color": "red", "value": 2.50 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 2,
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(kepler_node_platform_joules_total[2m])) / 1000 * ${electricity_cost} * 24",
          "legendFormat": "$/day",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Estimated Monthly Cost ($/mo)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 2,
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(kepler_node_platform_joules_total[2m])) / 1000 * ${electricity_cost} * 24 * 30",
          "legendFormat": "$/month",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Cost per Node ($/hr)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisLabel": "$/hr"
          },
          "unit": "currencyUSD",
          "decimals": 4,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "expr": "rate(kepler_node_platform_joules_total[2m]) / 1000 * ${electricity_cost}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1
      },
      {
        "name": "electricity_cost",
        "type": "custom",
        "label": "Electricity Cost ($/kWh)",
        "query": "0.10,0.12,0.14,0.16,0.18,0.20,0.25,0.30",
        "current": {
          "selected": true,
          "text": "0.16",
          "value": "0.16"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [
          {"selected": false, "text": "0.10", "value": "0.10"},
          {"selected": false, "text": "0.12", "value": "0.12"},
          {"selected": false, "text": "0.14", "value": "0.14"},
          {"selected": true,  "text": "0.16", "value": "0.16"},
          {"selected": false, "text": "0.18", "value": "0.18"},
          {"selected": false, "text": "0.20", "value": "0.20"},
          {"selected": false, "text": "0.25", "value": "0.25"},
          {"selected": false, "text": "0.30", "value": "0.30"}
        ]
      }
    ]
  },
  "schemaVersion": 38,
  "version": 1
}
